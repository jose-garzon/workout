# workout-pal — environment variables
#
# These are SERVER-ONLY secrets, read exclusively by
# src/app/api/generate-routine/route.ts (the stateless AI proxy). NEVER prefix
# them with NEXT_PUBLIC_ — that would ship them into the client bundle. The
# client never sees the key and never picks the model (design.md §0/§2).
#
# Copy to `.env.local` (gitignored) and fill in real values for local dev.

# OpenRouter API key (https://openrouter.ai/keys).
OPENROUTER_API_KEY=

# OpenRouter model id, e.g. anthropic/claude-3.5-sonnet, openai/gpt-4o, google/gemini-2.0-flash.
OPENROUTER_MODEL=

# Optional: override the OpenRouter base URL (defaults to https://openrouter.ai/api/v1).
# OPENROUTER_BASE_URL=

# Optional: per-IP rate limit on the AI proxy (design.md §D9). Defaults: 10 / 60s.
# Best-effort, in-memory, per-instance — pair with a platform/edge limit + an
# OpenRouter key spend cap for real protection.
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW_MS=60000
